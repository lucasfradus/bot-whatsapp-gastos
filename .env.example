# ID del grupo de WhatsApp donde opera el bot
# Para obtenerlo: el bot imprime los IDs de grupos al iniciar
WHATSAPP_GROUP_ID=

# ID de la Google Sheet (el string largo en la URL de tu spreadsheet)
# Ejemplo: https://docs.google.com/spreadsheets/d/ESTE_ES_EL_ID/edit
GOOGLE_SHEET_ID=

# Credenciales de Google Service Account (JSON en una línea)
# Ver README.md para instrucciones de cómo obtenerlas
GOOGLE_CREDENTIALS=
